---
import Layout from "../../components/Layout.astro";
import { projects } from "../../data/projects";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const rootPath = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
const projectLinks = [
  project.links.demo ? { label: "Demo", href: project.links.demo } : null,
  project.links.repo ? { label: "Repositório", href: project.links.repo } : null,
  project.links.writeup ? { label: "Write-up", href: project.links.writeup } : null
].filter(Boolean);
---

<Layout title={`${project.title} | Henrique`} description={project.summary}>
  <section class="container-shell py-14 md:py-20">
    <div class="mb-8 flex flex-wrap items-center gap-4">
      <a class="button-secondary px-4 py-2 text-sm" href={`${rootPath}#projetos`}>← Voltar aos projetos</a>
      <span class="terminal-chip">{project.category}</span>
    </div>

    <div class="section-frame overflow-hidden">
      <div class="border-b border-[color:var(--border)] px-8 py-10 md:px-12 md:py-14">
        <p class="eyebrow">Projeto</p>
        <h1 class="mt-5 max-w-4xl text-4xl font-semibold tracking-tight text-white md:text-6xl">{project.title}</h1>
        <p class="mt-5 max-w-3xl text-lg leading-8 text-[color:var(--text-soft)]">{project.summary}</p>
      </div>

      <div class="grid gap-6 px-8 py-8 md:grid-cols-[0.78fr_1.22fr] md:px-12 md:py-12">
        <aside class="space-y-4">
          <div class="card-panel p-5">
            <p class="font-mono text-xs uppercase tracking-[0.24em] text-[color:var(--accent)]">Tecnologias</p>
            <ul class="mt-4 flex flex-wrap gap-2">
              {project.technologies.map((item) => (
                <li class="tag-chip">{item}</li>
              ))}
            </ul>
          </div>

          {projectLinks.length > 0 && (
            <div class="card-panel p-5">
              <p class="font-mono text-xs uppercase tracking-[0.24em] text-[color:var(--accent)]">Links</p>
              <div class="mt-4 grid gap-3">
                {projectLinks.map((link) => (
                  <a class="button-secondary justify-between text-sm" href={link.href} target="_blank" rel="noreferrer">
                    <span>{link.label}</span>
                    <span class="font-mono text-xs uppercase tracking-[0.2em]">Abrir</span>
                  </a>
                ))}
              </div>
            </div>
          )}

          <div class="card-panel p-5">
            <p class="font-mono text-xs uppercase tracking-[0.24em] text-[color:var(--accent)]">Resultado</p>
            <p class="mt-4 text-sm leading-6 text-[color:var(--text-soft)]">{project.result}</p>
          </div>

          <div class="card-panel p-5">
            <p class="font-mono text-xs uppercase tracking-[0.24em] text-[color:var(--accent)]">Resumo rápido</p>
            <ul class="mt-4 grid gap-3 text-sm leading-6 text-[color:var(--text-soft)]">
              <li>• Projeto documentado em português</li>
              <li>• Estrutura focada em evidências e implementação</li>
              <li>• Contexto orientado a prática hands-on</li>
            </ul>
          </div>
        </aside>

        <div class="grid gap-6">
          <article class="card-panel p-6">
            <h2 class="font-mono text-xs uppercase tracking-[0.28em] text-[color:var(--accent)]">Resumo</h2>
            <p class="mt-4 text-base leading-7 text-[color:var(--text-soft)]">{project.summary}</p>
          </article>

          <article class="card-panel p-6">
            <h2 class="font-mono text-xs uppercase tracking-[0.28em] text-[color:var(--accent)]">Descrição</h2>
            <p class="mt-4 text-base leading-7 text-[color:var(--text-soft)]">{project.description}</p>
          </article>

          <article class="card-panel p-6">
            <h2 class="font-mono text-xs uppercase tracking-[0.28em] text-[color:var(--accent)]">Destaques</h2>
            <ul class="mt-4 grid gap-3 text-base leading-7 text-[color:var(--text-soft)]">
              {project.highlights.map((item) => <li>• {item}</li>)}
            </ul>
          </article>
        </div>
      </div>
    </div>
  </section>
</Layout>
