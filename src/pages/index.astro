---
import Layout from "../components/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionTitle from "../components/SectionTitle.astro";
import { featuredProjects, intermediateProjects, toolProjects } from "../data/projects";
import { profile } from "../data/site";
---

<Layout>
  <section class="container-shell anchor-offset grid min-h-[calc(100vh-5rem)] items-center gap-10 py-16 md:grid-cols-[1.15fr_0.85fr] md:py-24">
    <div class="space-y-8">
      <span class="eyebrow">Blue Team • Logs • Hardening</span>

      <div class="space-y-6">
        <h1 class="max-w-4xl text-5xl font-semibold tracking-tight text-white md:text-7xl">
          Henrique, <span class="signal-line text-[color:var(--accent)]">Analista de Cibersegurança</span>
          com foco em defesa prática e visibilidade operacional.
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-[color:var(--text-soft)] md:text-xl">{profile.headline}</p>
        <p class="max-w-2xl text-base leading-7 text-[color:var(--text-muted)]">{profile.about}</p>
      </div>

      <div class="flex flex-col gap-4 sm:flex-row">
        <a class="button-primary" href="#projetos">Explorar projetos</a>
        <a class="button-secondary" href="#contato">Entrar em contato</a>
      </div>

      <div class="grid gap-3 sm:grid-cols-3">
        {profile.stats.map((stat) => (
          <div class="metric-card">
            <span>{stat.label}</span>
            <strong>{stat.value}</strong>
          </div>
        ))}
      </div>
    </div>

    <aside class="section-frame relative overflow-hidden p-8">
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[color:var(--accent)] to-transparent"></div>
      <div class="space-y-8">
        <div class="flex items-center justify-between font-mono text-xs uppercase tracking-[0.3em] text-[color:var(--text-soft)]">
          <span>Threat Visibility</span>
          <span class="text-[color:var(--accent-warm)]">Online</span>
        </div>

        <div class="dashboard-grid">
          <div class="dashboard-panel">
            <p class="dashboard-label">Foco atual</p>
            <p class="dashboard-value">{profile.focus}</p>
          </div>
          <div class="dashboard-panel">
            <p class="dashboard-label">Stack</p>
            <p class="dashboard-value">Astro, TailwindCSS, GitHub Pages</p>
          </div>
          <div class="dashboard-panel">
            <p class="dashboard-label">Prática</p>
            <p class="dashboard-value">Laboratórios Linux, análise de eventos e tuning de observabilidade.</p>
          </div>
          <div class="dashboard-panel">
            <p class="dashboard-label">Objetivo</p>
            <p class="dashboard-value">Demonstrar experiência técnica real com projetos hands-on.</p>
          </div>
        </div>

        <div class="card-panel p-5">
          <p class="font-mono text-xs uppercase tracking-[0.22em] text-[color:var(--accent)]">Pipeline operacional</p>
          <ul class="mt-4 grid gap-3 text-sm leading-6 text-[color:var(--text-soft)]">
            <li>01. Coleta e normalização de logs</li>
            <li>02. Correlação de sinais e triagem</li>
            <li>03. Hardening e melhoria contínua</li>
          </ul>
        </div>
      </div>
    </aside>
  </section>

  <section id="sobre" class="container-shell anchor-offset py-10 md:py-16">
    <div class="section-frame grid gap-8 p-8 md:grid-cols-[0.8fr_1.2fr] md:p-12">
      <SectionTitle
        eyebrow="Sobre"
        title="Experiência prática em segurança defensiva, laboratórios e operação Linux."
        description="O portfólio prioriza clareza técnica, evidências e documentação objetiva sobre como cada projeto funciona."
      />

      <div class="grid gap-5 text-base leading-7 text-[color:var(--text-soft)]">
        <p>
          Meu trabalho é orientado à segurança defensiva, análise de eventos e construção de ambientes que simulam cenários
          reais. A proposta é mostrar execução, troubleshooting e capacidade de transformar telemetria em decisão.
        </p>
        <p>
          Em vez de focar em certificações, este site destaca projetos, laboratórios e ferramentas que demonstram postura
          prática com Linux, SIEM, Python e processos de hardening.
        </p>

        <div class="grid gap-4 pt-2 sm:grid-cols-2">
          {profile.highlights.map((item) => (
            <div class="card-panel p-5">
              <p class="font-mono text-xs uppercase tracking-[0.24em] text-[color:var(--accent)]">Capacidade</p>
              <p class="mt-3 text-sm leading-6 text-white">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="projetos" class="container-shell anchor-offset py-10 md:py-16">
    <div class="space-y-10">
      <SectionTitle
        eyebrow="Projetos"
        title="Projetos e laboratórios criados para demonstrar maturidade técnica real."
        description="A seleção combina ambientes de laboratório, estudos aplicados e ferramentas utilitárias que reforçam o perfil hands-on."
      />

      <div class="space-y-12">
        <div class="space-y-5">
          <div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
            <h3 class="font-mono text-sm uppercase tracking-[0.26em] text-[color:var(--accent)]">Projetos principais</h3>
            <span class="text-sm text-[color:var(--text-soft)]">Maior profundidade técnica e contexto operacional</span>
          </div>
          <div class="grid gap-6 lg:grid-cols-3">
            {featuredProjects.map((project) => <ProjectCard project={project} />)}
          </div>
        </div>

        <div class="space-y-5">
          <div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
            <h3 class="font-mono text-sm uppercase tracking-[0.26em] text-[color:var(--accent)]">Projetos intermediários</h3>
            <span class="text-sm text-[color:var(--text-soft)]">Estudo aplicado, detecção e raciocínio defensivo</span>
          </div>
          <div class="grid gap-6 md:grid-cols-2">
            {intermediateProjects.map((project) => <ProjectCard project={project} />)}
          </div>
        </div>

        <div class="space-y-5">
          <div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
            <h3 class="font-mono text-sm uppercase tracking-[0.26em] text-[color:var(--accent)]">Ferramentas</h3>
            <span class="text-sm text-[color:var(--text-soft)]">Utilitários criados para tarefas práticas do dia a dia</span>
          </div>
          <div class="grid gap-6 md:grid-cols-2">
            {toolProjects.map((project) => <ProjectCard project={project} />)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="medium" class="container-shell anchor-offset py-10 md:py-16">
    <div class="section-frame grid gap-8 p-8 md:grid-cols-[1fr_0.75fr] md:p-12">
      <SectionTitle
        eyebrow="Medium"
        title="Artigos técnicos para aprofundar metodologia, troubleshooting e aprendizados."
        description="A seção direciona o visitante para publicações no Medium sem depender de integração com API neste momento."
      />

      <div class="card-panel flex flex-col justify-between gap-6 p-6">
        <div class="space-y-4">
          <p class="text-base leading-7 text-[color:var(--text-soft)]">
            Espaço destinado a write-ups, estudos de hardening, tuning de SIEM, análises de logs e documentação de laboratório.
          </p>
          <div class="grid gap-3 text-sm text-[color:var(--text-muted)]">
            <span>• Postura defensiva aplicada</span>
            <span>• Evidências e metodologia</span>
            <span>• Conteúdo técnico direto em português</span>
          </div>
        </div>

        <a class="button-primary w-fit" href={profile.mediumUrl} target="_blank" rel="noreferrer">Abrir Medium</a>
      </div>
    </div>
  </section>

  <section id="contato" class="container-shell anchor-offset py-10 pb-20 md:py-16 md:pb-24">
    <div class="section-frame grid gap-8 p-8 md:grid-cols-[1fr_0.95fr] md:p-12">
      <SectionTitle
        eyebrow="Contato"
        title="Disponível para conversar sobre segurança defensiva, laboratórios e projetos técnicos."
        description="A área de contato mantém o foco profissional do portfólio e facilita conexões com recrutadores e equipes técnicas."
      />

      <div class="grid gap-4">
        <a class="button-secondary justify-between" href={`mailto:${profile.email}`}>
          <span>Email</span>
          <span class="font-mono text-xs uppercase tracking-[0.24em]">{profile.email}</span>
        </a>
        <a class="button-secondary justify-between" href={profile.githubUrl} target="_blank" rel="noreferrer">
          <span>GitHub</span>
          <span class="font-mono text-xs uppercase tracking-[0.24em]">Repositórios e código</span>
        </a>
        <a class="button-secondary justify-between" href={profile.linkedinUrl} target="_blank" rel="noreferrer">
          <span>LinkedIn</span>
          <span class="font-mono text-xs uppercase tracking-[0.24em]">Perfil profissional</span>
        </a>
      </div>
    </div>
  </section>
</Layout>
