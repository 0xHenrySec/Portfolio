---
import "../styles/global.css";
import { profile, siteMeta } from "../data/site";

interface Props {
  title?: string;
  description?: string;
}

const { title = siteMeta.title, description = siteMeta.description } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const navLinks = [
  { label: "Home", href: baseUrl },
  { label: "Projetos", href: `${baseUrl}#projetos` },
  { label: "Medium", href: `${baseUrl}#medium` },
  { label: "Contato", href: `${baseUrl}#contato` }
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#071014" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <header class="sticky top-0 z-40 border-b border-[color:var(--border)] bg-[rgba(3,8,11,0.78)] backdrop-blur-xl">
      <div class="container-shell flex flex-col gap-4 py-4 md:flex-row md:items-center md:justify-between">
        <div class="flex items-center justify-between gap-4">
          <a href={baseUrl} class="font-mono text-sm uppercase tracking-[0.28em] text-white">
            {profile.name}
          </a>
          <span class="terminal-chip hidden md:inline-flex">{profile.role}</span>
        </div>

        <nav aria-label="principal">
          <ul class="flex flex-wrap items-center gap-3 font-mono text-[11px] uppercase tracking-[0.24em] text-[color:var(--text-soft)] md:gap-6 md:text-xs">
            {navLinks.map((item) => (
              <li>
                <a class="nav-link" href={item.href}>{item.label}</a>
              </li>
            ))}
          </ul>
        </nav>

        <a class="button-secondary text-sm" href={`${baseUrl}#projetos`}>Explorar projetos</a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-[color:var(--border)] py-8">
      <div class="container-shell flex flex-col gap-4 text-sm text-[color:var(--text-soft)] md:flex-row md:items-center md:justify-between">
        <p>Portfólio técnico de cibersegurança com foco em prática, laboratório e operação defensiva.</p>
        <div class="flex flex-wrap gap-4 font-mono text-xs uppercase tracking-[0.22em]">
          <a href={profile.githubUrl} target="_blank" rel="noreferrer">GitHub</a>
          <a href={profile.linkedinUrl} target="_blank" rel="noreferrer">LinkedIn</a>
          <a href={profile.mediumUrl} target="_blank" rel="noreferrer">Medium</a>
        </div>
      </div>
    </footer>
  </body>
</html>
