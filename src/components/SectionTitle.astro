---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="section-title max-w-2xl">
  <span>{eyebrow}</span>
  <h2 class="text-3xl font-semibold tracking-tight text-white md:text-4xl">{title}</h2>
  <p class="text-base leading-7 text-[color:var(--text-soft)] md:text-lg">{description}</p>
</div>
